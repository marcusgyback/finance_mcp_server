# Filestash endpoint — typically https://your-filestash-instance.com/api/s3
S3_ENDPOINT_URL=https://your-filestash-instance.com/api/s3
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Path to the client registry file (default: clients.json in project root)
CLIENTS_FILE=clients.json
